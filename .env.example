# ═══ Claude Java Toolkit — Docker 환경변수 ═══
# 이 파일을 .env 로 복사하여 값을 설정하세요:
#   cp .env.example .env

# ── Claude API ──
CLAUDE_API_KEY=sk-ant-api03-your-key-here

# ── 내부 DB 설정 (애플리케이션 데이터 저장용) ──
# h2 (기본값, 파일 DB) | mysql | postgresql
DB_TYPE=h2

# MySQL/PostgreSQL 사용 시 설정
DB_HOST=db
DB_PORT=3306
DB_NAME=claude_toolkit
DB_USERNAME=claude
DB_PASSWORD=claude1234

# ── 서버 ──
PORT=8027
JAVA_OPTS=-Xmx512m
